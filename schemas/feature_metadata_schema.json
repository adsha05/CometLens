{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "AxionAI Feature Metadata",
  "type": "object",
  "required": ["entity_id", "target", "features"],
  "properties": {
    "entity_id": {
      "type": "string",
      "minLength": 1
    },
    "target": {
      "type": "string",
      "minLength": 1
    },
    "features": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["name", "type"],
        "properties": {
          "name": {
            "type": "string",
            "minLength": 1
          },
          "type": {
            "type": "string",
            "enum": ["numeric", "categorical", "ordinal", "boolean", "datetime"]
          },
          "business_definition": {
            "type": "string"
          },
          "synthetic_only": {
            "type": "boolean"
          },
          "nullable": {
            "type": "boolean"
          },
          "expected_min": {
            "type": "number"
          },
          "expected_max": {
            "type": "number"
          }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}
